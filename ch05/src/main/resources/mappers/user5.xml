<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace 속성은 해당 매퍼파일을 연결할 매퍼클래스(DAO) 설정(패키지포함) -->
<mapper namespace="org.example.ch05.dao.User5DAO">

    <!-- id값은 DAO의 메서드명으로 맞춰줌 -->
    <select id="select" resultType="org.example.ch05.dto.User5DTO">
        SELECT * FROM User5 WHERE userid=#{userid};
    </select>

    <select id="selectAll" resultType="org.example.ch05.dto.User5DTO">
        SELECT * FROM User5;
    </select>

    <insert id="insert">
        INSERT INTO User5 SET

                            name=#{name},
                            gender=#{gender},
                            age=#{age},
                            addr=#{addr};
    </insert>

    <update id="update">
        UPDATE User5 SET

                            gender=#{gender},
                            age=#{age},
                            addr=#{addr}
                        WHERE
                            name=#{name};
    </update>

    <delete id="delete">
        DELETE FROM User5 WHERE name=#{name};
    </delete>
</mapper>